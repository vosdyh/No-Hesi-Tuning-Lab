<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>No Hesi | Tuning Lab v1.8.7</title>
    <!-- Tailwind CSS Play CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'system-ui', '-apple-system', 'sans-serif'],
                        mono: ['JetBrains Mono', 'Monaco', 'Consolas', 'monospace']
                    }
                }
            }
        }
    </script>
    <style>
        :root { 
            --bg: #121318; 
            --card: #1a1c23; 
            --text: #f4f4f5; 
            --border: #27272a; 
            --gradient-start: #a855f7; 
            --gradient-end: #ec4899; 
            --accent: #a855f7;
        }
        
        body { 
            background-color: var(--bg); 
            color: var(--text); 
            font-family: 'Inter', system-ui, sans-serif; 
            transition: background-color 0.25s ease, color 0.25s ease;
            overflow-x: hidden;
        }

        /* Tactile Mechanical Feedback */
        .btn-tactile { 
            transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1); 
            cursor: pointer; 
        }
        .btn-tactile:active { 
            transform: scale(0.95) translateY(1px); 
        }

        /* Horizontal Screen-Vibration (Jiggle) Animation */
        @keyframes jiggle { 
            0% { transform: translateX(0); } 
            20% { transform: translateX(-6px); } 
            40% { transform: translateX(5px); } 
            60% { transform: translateX(-5px); } 
            80% { transform: translateX(3px); } 
            100% { transform: translateX(0); } 
        }
        .animate-jiggle { 
            animation: jiggle 0.3s cubic-bezier(.36,.07,.19,.97) both; 
        }

        /* Dynamic Gradient Border Stroke */
        .gradient-stroke { 
            background: linear-gradient(var(--card), var(--card)) padding-box, 
                        linear-gradient(to right, var(--gradient-start), var(--gradient-end)) border-box;
            border: 1px solid transparent;
        }

        /* Card Edge Visual Redline Effect (from v27 UI) */
        .rpm-border { 
            position: relative; 
            background: var(--card); 
            border-radius: 12px;
        }
        .rpm-border::before {
            content: ''; 
            position: absolute; 
            inset: -1px; 
            background: linear-gradient(90deg, var(--gradient-start), var(--gradient-end));
            z-index: -1; 
            border-radius: 13px;
            opacity: 0.85;
            transition: all 0.25s ease;
        }

        /* Custom Scrollbars */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: rgba(0, 0, 0, 0.1);
        }
        ::-webkit-scrollbar-thumb {
            background: #27272a;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #3f3f46;
        }

        /* Modal Architecture blur */
        .modal-backdrop { 
            backdrop-filter: blur(8px); 
            background: rgba(9, 9, 11, 0.75); 
            opacity: 0; 
            visibility: hidden; 
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1); 
        }
        .modal-backdrop.is-open { 
            opacity: 1; 
            visibility: visible; 
        }
        .modal-container { 
            background-color: #0d0e12; 
            border: 1px solid #27272a; 
            transform: translateY(-20px) scale(0.95); 
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1); 
            opacity: 0; 
        }
        .modal-backdrop.is-open .modal-container { 
            transform: translateY(0) scale(1); 
            opacity: 1; 
        }
    </style>
</head>
<body class="min-h-screen flex flex-col justify-between">

    <!-- MASTER CONTAINER FOR JIGGLE -->
    <div id="masterWrapper" class="flex-grow flex flex-col justify-between">

        <!-- HEADER & APP CONTENT -->
        <div class="relative z-10 max-w-6xl mx-auto p-4 md:p-8 w-full flex-grow">
            
            <!-- HEADER -->
            <header class="mb-8 border-b border-zinc-800/80 pb-6 flex flex-col md:flex-row md:justify-between md:items-center gap-6">
                <div class="flex flex-col gap-1.5">
                    <div class="flex items-center gap-6 flex-wrap">
                        <div onclick="triggerJiggle()" class="flex items-center gap-2 text-2xl font-black tracking-tighter uppercase text-white italic group btn-tactile select-none">
                            <span class="p-1.5 rounded-lg bg-[#1a1c23] border border-zinc-800 text-[var(--accent)] group-hover:scale-105 transition-transform" id="logoBox">
                                <!-- Tuning Sliders SVG -->
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75" />
                                </svg>
                            </span>
                            <span class="text-white">NO HESI<span id="themeTextAccent" class="text-[var(--accent)] transition-all duration-300">.LAB</span></span>
                        </div>
                        
                        <nav class="flex items-center gap-5 text-[11px] uppercase tracking-widest font-bold text-zinc-400">
                            <button onclick="triggerJiggle()" class="hover:text-white btn-tactile transition-colors">Lab Home</button>
                            <button onclick="openModal('chassisDbModal')" class="hover:text-white btn-tactile transition-colors flex items-center gap-1">
                                <!-- DB SVG -->
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75" />
                                </svg>
                                Chassis DB
                            </button>
                            <button onclick="openModal('presetsModal')" class="hover:text-white btn-tactile transition-colors flex items-center gap-1.5">
                                <!-- Bookmark SVG -->
                                <svg class="w-3.5 h-3.5 text-[var(--accent)]" id="navBookmarkIcon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0z" />
                                </svg>
                                <span>Saved Presets</span>
                                <span id="presetsCountBadge" class="hidden px-1.5 py-0.5 text-[9px] bg-[var(--accent)] text-black font-bold rounded-full">0</span>
                            </button>
                            <button onclick="openModal('iniModal')" class="hover:text-white btn-tactile transition-colors flex items-center gap-1 text-[var(--accent)]" id="navExportBtn">
                                <!-- Download SVG -->
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                                </svg>
                                <span>Export AC Setup</span>
                            </button>
                        </nav>
                    </div>
                    <p class="text-[10px] text-zinc-500 font-mono tracking-widest flex items-center gap-2 select-none">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                        Engine v1.8.7 // Deep-Tier Physics Stable // AC Setup Ready
                    </p>
                </div>

                <button onclick="openModal('settingsModal')" class="px-4 py-2.5 bg-[#1a1c23] border border-zinc-700 hover:border-zinc-500 text-xs text-white uppercase font-bold tracking-widest btn-tactile rounded-xl flex items-center justify-center gap-2 shadow-sm">
                    <!-- Gear SVG -->
                    <svg class="w-3.5 h-3.5 text-[var(--accent)]" id="configGearIcon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.43l-1.003.828c-.293.241-.438.613-.43.992a7.723 7.723 0 010 .255c-.008.378.137.75.43.992l1.004.827c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.43l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.991l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.28z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <span>Configure Environment ↗</span>
                </button>
            </header>

            <!-- 4 Rounded CONFIG INPUTS AT THE TOP -->
            <div class="mb-6 space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-3">
                    
                    <!-- Chassis Input Box with Suggestions Dropdown -->
                    <div class="relative">
                        <label class="block text-[10px] font-bold text-zinc-400 mb-1.5 uppercase tracking-widest flex items-center gap-1 select-none">
                            <span class="w-1.5 h-1.5 rounded-full bg-[var(--accent)]" id="bulletChassis"></span> Chassis Identifier
                        </label>
                        <div class="relative flex">
                            <input type="text" id="carInput" oninput="runCalculations()" placeholder="e.g. Supra JZA80, Mustang GT500, S2000..." class="gradient-stroke bg-[#1a1c23] p-3 text-sm text-white placeholder-zinc-600 outline-none rounded-xl w-full focus:border-[var(--accent)] font-mono transition-all">
                            <button onclick="toggleCarList()" class="absolute right-3 top-3.5 text-zinc-500 hover:text-white btn-tactile">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
                            </button>
                        </div>
                        <div id="carListDropdown" class="hidden absolute left-0 right-0 top-full mt-1 bg-[#14161d] border border-zinc-800 rounded-xl max-h-60 overflow-y-auto z-50 shadow-2xl">
                            <!-- Dynamic chassis items loaded by JS -->
                        </div>
                    </div>

                    <!-- Compound Selection Dropdown -->
                    <div>
                        <label class="block text-[10px] font-bold text-zinc-400 mb-1.5 uppercase tracking-widest flex items-center gap-1 select-none">
                            <span class="w-1.5 h-1.5 rounded-full bg-[var(--accent)]" id="bulletTyres"></span> Tyre Compound
                        </label>
                        <select id="tyreSelect" onchange="runCalculations()" class="gradient-stroke bg-[#1a1c23] p-3 text-sm text-white outline-none rounded-xl w-full btn-tactile focus:border-[var(--accent)] transition-all">
                            <option value="dry">🏎️ Dry Slicks (Hot lap / Max Grip)</option>
                            <option value="street">🛣️ Street Tyres (Balanced Traffic)</option>
                            <option value="rain">🌧️ Rain / Wet (Hydroplaning Soft)</option>
                            <option value="drift">💨 Drift Hard-Compounds (Rear Slip)</option>
                        </select>
                    </div>

                    <!-- Gearbox dropdown -->
                    <div>
                        <label class="block text-[10px] font-bold text-zinc-400 mb-1.5 uppercase tracking-widest flex items-center gap-1 select-none">
                            <span class="w-1.5 h-1.5 rounded-full bg-[var(--accent)]" id="bulletGearing"></span> Transmission Gearing
                        </label>
                        <select id="gearSelect" onchange="runCalculations()" class="gradient-stroke bg-[#1a1c23] p-3 text-sm text-white outline-none rounded-xl w-full btn-tactile focus:border-[var(--accent)] transition-all">
                            <option value="vshort">⚡ Very Short (Drift / Rapid Pulls)</option>
                            <option value="short">🚦 Short Gears (Highway Traffic Weave)</option>
                            <option value="standard" selected>⚙️ Standard Factory Gearing</option>
                            <option value="long">🚀 Long Gears (Vmax Top-Speed Run)</option>
                        </select>
                    </div>

                    <!-- Traffic Density dropdown -->
                    <div>
                        <label class="block text-[10px] font-bold text-zinc-400 mb-1.5 uppercase tracking-widest flex items-center gap-1 select-none">
                            <span class="w-1.5 h-1.5 rounded-full bg-[var(--accent)]" id="bulletTraffic"></span> Traffic Density
                        </label>
                        <select id="trafficSelect" onchange="runCalculations()" class="gradient-stroke bg-[#1a1c23] p-3 text-sm text-white outline-none rounded-xl w-full btn-tactile focus:border-[var(--accent)] transition-all">
                            <option value="light">🟢 Light Traffic (Wide Open Runs)</option>
                            <option value="medium" selected>🟡 Medium Traffic (Standard SRP)</option>
                            <option value="heavy">🔴 Heavy Traffic (Tight Cutting & Evasive)</option>
                        </select>
                    </div>

                </div>

                <!-- QUICK MODES BAR & STIFFNESS -->
                <div class="flex flex-wrap items-center justify-between gap-3 p-3 bg-[#1a1c23] border border-zinc-800 rounded-xl">
                    <div class="flex items-center gap-3">
                        <span class="text-xs font-semibold uppercase tracking-wider text-zinc-400 select-none">Target Goal:</span>
                        <div class="flex gap-1" id="modeTabs">
                            <button onclick="setDrivingStyle('weave')" id="btn-mode-weave" class="px-3 py-1.5 text-xs font-bold rounded-lg btn-tactile border border-zinc-800 bg-zinc-900 text-zinc-400">Weaving</button>
                            <button onclick="setDrivingStyle('vmax')" id="btn-mode-vmax" class="px-3 py-1.5 text-xs font-bold rounded-lg btn-tactile border border-zinc-800 bg-zinc-900 text-zinc-400">Vmax Run</button>
                            <button onclick="setDrivingStyle('drift')" id="btn-mode-drift" class="px-3 py-1.5 text-xs font-bold rounded-lg btn-tactile border border-zinc-800 bg-zinc-900 text-zinc-400">Drift</button>
                            <button onclick="setDrivingStyle('grip')" id="btn-mode-grip" class="px-3 py-1.5 text-xs font-bold rounded-lg btn-tactile border border-zinc-800 bg-zinc-900 text-zinc-400">Track/Touge</button>
                        </div>
                    </div>
                    
                    <button onclick="toggleAdvancedSettings()" class="flex items-center gap-1.5 text-xs font-bold uppercase tracking-wider text-[var(--accent)] hover:underline btn-tactile py-1">
                        <!-- Sliders SVG -->
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
                        </svg>
                        <span>Fine-Tune Modifiers</span>
                        <svg class="w-3.5 h-3.5 transition-transform" id="advancedChevron" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
                    </button>
                </div>

                <!-- EXPANDABLE ADVANCED TUNING CONTROLS -->
                <div id="advancedPanel" class="hidden p-4 bg-[#1a1c23] border border-zinc-800 rounded-xl space-y-4 animate-fadeIn">
                    <div class="flex justify-between items-center border-b border-zinc-800/80 pb-2">
                        <h4 class="text-xs font-bold uppercase tracking-widest text-white flex items-center gap-1.5">
                            Chassis & Power Fine-Tuning Modifiers
                        </h4>
                        <button onclick="resetAdvancedSliders()" class="text-[10px] text-zinc-500 hover:text-zinc-300 underline uppercase tracking-wider">
                            Reset Modifiers
                        </button>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                        <!-- Weight Modifier -->
                        <div>
                            <div class="flex justify-between text-xs mb-1 select-none">
                                <span class="text-zinc-400 font-medium">Weight Offset</span>
                                <span class="font-mono text-white font-bold" id="weightVal">0 kg</span>
                            </div>
                            <input type="range" id="weightSlider" min="-300" max="300" step="10" value="0" oninput="updateSlidersText(); runCalculations();" class="w-full accent-[var(--accent)] cursor-pointer">
                        </div>

                        <!-- HP Modifier -->
                        <div>
                            <div class="flex justify-between text-xs mb-1 select-none">
                                <span class="text-zinc-400 font-medium">Power Offset</span>
                                <span class="font-mono text-white font-bold" id="hpVal">0 HP</span>
                            </div>
                            <input type="range" id="hpSlider" min="-200" max="600" step="25" value="0" oninput="updateSlidersText(); runCalculations();" class="w-full accent-[var(--accent)] cursor-pointer">
                        </div>

                        <!-- Stiffness modifier -->
                        <div>
                            <div class="flex justify-between text-xs mb-1 select-none">
                                <span class="text-zinc-400 font-medium">Spring Stiffness</span>
                                <span class="font-mono text-white font-bold" id="stiffnessVal">1.00x</span>
                            </div>
                            <input type="range" id="stiffnessSlider" min="0.7" max="1.4" step="0.05" value="1.0" oninput="updateSlidersText(); runCalculations();" class="w-full accent-[var(--accent)] cursor-pointer">
                        </div>

                        <!-- Traction Control switch -->
                        <div class="flex items-center justify-between p-2.5 bg-zinc-900/60 border border-zinc-800 rounded-lg">
                            <span class="text-xs font-bold text-zinc-300 uppercase tracking-wider select-none">Allow AC TC</span>
                            <input type="checkbox" id="tcAllowed" onchange="runCalculations()" class="w-4 h-4 accent-[var(--accent)] cursor-pointer rounded">
                        </div>
                    </div>
                </div>
            </div>

            <!-- CHASSIS TELEMETRY DIAGRAM & QUICK SPECS -->
            <div class="gradient-stroke p-[1px] rounded-2xl mb-8" id="telemetryBoxBorder">
                <div class="bg-[#1a1c23] p-5 md:p-6 rounded-2xl">
                    
                    <!-- Quick Specs Header -->
                    <div class="flex flex-col lg:flex-row items-center justify-between gap-6 border-b border-zinc-800 pb-6 mb-6">
                        <div class="w-full lg:w-auto">
                            <div class="flex items-center gap-2 text-[10px] uppercase tracking-widest font-bold text-[var(--accent)] mb-1 select-none">
                                <!-- Compass SVG -->
                                <svg class="w-3.5 h-3.5 text-[var(--accent)]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25s-7.5-4.108-7.5-11.25A7.5 7.5 0 1119.5 10.5z" />
                                </svg>
                                Chassis Benchmarks & Metadata
                            </div>
                            <h2 class="text-xl font-extrabold text-white tracking-tight italic uppercase" id="carTitle">
                                Toyota Supra JZA80
                            </h2>
                            <div class="flex items-center gap-3 text-[11px] text-zinc-400 font-mono mt-1 flex-wrap select-none">
                                <span class="px-2 py-0.5 rounded bg-zinc-900 border border-zinc-800 text-zinc-200" id="carDrivetrain">RWD</span>
                                <span id="carWeight">1510 kg</span>
                                <span>•</span>
                                <span class="text-amber-400" id="carHp">680 HP</span>
                                <span>•</span>
                                <span class="text-emerald-400 font-bold" id="carPwrWeight">450.3 HP/Ton</span>
                                <span>•</span>
                                <span class="text-purple-400 uppercase tracking-widest text-[9px] font-bold" id="carArchetype">JDM/Tuner</span>
                            </div>
                        </div>

                        <!-- Telemetry Grid Stats -->
                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 w-full lg:w-auto">
                            <!-- Grip -->
                            <div class="p-3 bg-zinc-900/60 border border-zinc-800/80 rounded-xl text-center">
                                <div class="data-label select-none">Lat. Grip</div>
                                <div class="data-val text-lg font-black text-white mt-0.5" id="specGrip">1.35 <span class="text-xs text-zinc-500 font-medium">G</span></div>
                            </div>
                            <!-- Agility -->
                            <div class="p-3 bg-zinc-900/60 border border-zinc-800/80 rounded-xl text-center">
                                <div class="data-label select-none">Weave Index</div>
                                <div class="data-val text-lg font-black text-amber-400 mt-0.5" id="specWeave">82 <span class="text-xs text-zinc-500 font-medium">/100</span></div>
                            </div>
                            <!-- Est Vmax -->
                            <div class="p-3 bg-zinc-900/60 border border-zinc-800/80 rounded-xl text-center">
                                <div class="data-label select-none">Est Vmax</div>
                                <div class="data-val text-lg font-black text-cyan-300 mt-0.5" id="specVmax">215 <span class="text-xs text-zinc-500 font-medium">MPH</span></div>
                            </div>
                            <!-- Roll balance -->
                            <div class="p-3 bg-zinc-900/60 border border-zinc-800/80 rounded-xl text-center">
                                <div class="data-label select-none">Front Roll</div>
                                <div class="data-val text-lg font-black text-purple-300 mt-0.5" id="specRoll">55%</div>
                            </div>
                        </div>
                    </div>

                    <!-- Layout of Wheels Diagram & Optimizations -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-center">
                        
                        <!-- Visual Chassis Wheel Diagram -->
