                    <div class="flex items-center gap-2 shrink-0">
                        <button onclick="loadSavedPresetByIndex(${index})" class="px-2.5 py-1.5 bg-zinc-800 text-zinc-200 hover:bg-[var(--accent)] hover:text-black text-xs font-bold uppercase tracking-wider rounded-lg btn-tactile transition-colors">
                            Load
                        </button>
                        <button onclick="deletePresetByIndex(${index})" class="p-2 text-zinc-600 hover:text-red-400 rounded-lg btn-tactile transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                        </button>
                    </div>
                </div>
            `).join('');
        }

        function saveActiveSetup(e) {
            if (e) e.preventDefault();
            const inputName = document.getElementById('presetNameInput');
            const name = inputName.value.trim();
            if (!name) return;

            const newPreset = {
                name: name,
                chassis: document.getElementById('carInput').value,
                compound: document.getElementById('tyreSelect').value,
                style: activeDrivingStyle,
                // store all config states
                gear: document.getElementById('gearSelect').value,
                traffic: document.getElementById('trafficSelect').value,
                weight: document.getElementById('weightSlider').value,
                hp: document.getElementById('hpSlider').value,
                stiffness: document.getElementById('stiffnessSlider').value,
                tc: document.getElementById('tcAllowed').checked
            };

            customPresets.unshift(newPreset);
            localStorage.setItem('customPresets_v29', JSON.stringify(customPresets));
            inputName.value = '';
            
            renderPresetsList();
            triggerJiggle();
        }

        function loadSavedPresetByIndex(index) {
            const p = customPresets[index];
            if (!p) return;

            document.getElementById('carInput').value = p.chassis;
            document.getElementById('tyreSelect').value = p.compound;
            document.getElementById('gearSelect').value = p.gear ?? 'standard';
            document.getElementById('trafficSelect').value = p.traffic ?? 'medium';
            document.getElementById('weightSlider').value = p.weight ?? 0;
            document.getElementById('hpSlider').value = p.hp ?? 0;
            document.getElementById('stiffnessSlider').value = p.stiffness ?? 1.0;
            document.getElementById('tcAllowed').checked = p.tc ?? false;

            updateSlidersText();
            setDrivingStyle(p.style || 'weave');
            closeModal('presetsModal');
            triggerJiggle();
        }

        function deletePresetByIndex(idx) {
            customPresets.splice(idx, 1);
            localStorage.setItem('customPresets_v29', JSON.stringify(customPresets));
            renderPresetsList();
        }

        // Initialize App states on document load
        document.addEventListener('DOMContentLoaded', () => {
            initChassisDropdown();
            renderThemeSelectorMatrix();
            applyGlobalTheme(activeThemeName);
            updateSlidersText();
            setDrivingStyle(activeDrivingStyle);
            
            // Set layout & style labels inside settings
            document.getElementById('currentLayoutText').innerText = isGrid ? 'Grid Cards' : 'Stacked List';
            document.getElementById('currentCardStyleText').innerText = cardStyle === 'rpm-border' ? 'RPM Redline (v27)' : 'Tactile Gradient Stroke (v28)';
            
            // Seed badges
            renderPresetsList();
        });
    </script>
</body>
</html>
