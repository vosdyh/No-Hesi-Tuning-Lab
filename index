            "Biolume Trench": { bg: "#020617", card: "#0f172a", start: "#06b6d4", end: "#38bdf8", accent: "#06b6d4" },
            "Forest Moss": { bg: "#05100d", card: "#0e1a16", start: "#10b981", end: "#34d399", accent: "#10b981" },
            "Desert Gold": { bg: "#1a120b", card: "#2d2010", start: "#f59e0b", end: "#facc15", accent: "#f59e0b" },
            "High Voltage": { bg: "#16110f", card: "#261a15", start: "#f97316", end: "#ef4444", accent: "#f97316" },
            "Hot Lap Carbon": { bg: "#0f0f0f", card: "#1f1f1f", start: "#dc2626", end: "#991b1b", accent: "#dc2626" },
            "Cotton Candy Dark": { bg: "#1a0812", card: "#330b20", start: "#f472b6", end: "#ff85c2", accent: "#f472b6" }
        };

        // 3. INTERNAL APP STATE (RESTORED OR DEFAULTS)
        let isGrid = JSON.parse(localStorage.getItem('isGrid_v29')) ?? true;
        let activeThemeName = localStorage.getItem('theme_v29') ?? "No Hesi Official";
        let cardStyle = localStorage.getItem('cardStyle_v29') ?? "rpm-border"; // "rpm-border" vs "gradient-stroke"
        let activeDrivingStyle = "weave"; // "weave" | "vmax" | "drift" | "grip"
        let customPresets = JSON.parse(localStorage.getItem('customPresets_v29')) ?? [];

        // Currently selected chassis index
        let selectedCarPreset = CAR_PRESETS[0];

        // Trigger dynamic jiggle animations for visual feedback
        function triggerJiggle() {
            const wrapper = document.getElementById('masterWrapper');
            wrapper.classList.remove('animate-jiggle');
            void wrapper.offsetWidth; // Force CSS repaint trigger
            wrapper.classList.add('animate-jiggle');
        }

        // Open & close dialog layouts
        function openModal(id) {
            const el = document.getElementById(id);
            if (el) el.classList.add('is-open');
            if (id === 'presetsModal') {
                renderPresetsList();
            }
        }
        function closeModal(id) {
            const el = document.getElementById(id);
            if (el) el.classList.remove('is-open');
        }

        // Handle overlay backdrop outer clicks
        document.querySelectorAll('.modal-backdrop').forEach(modal => {
            modal.addEventListener('click', function(e) {
                if (e.target === this) closeModal(this.id);
            });
        });

        // Initialize autocompletes
        function initChassisDropdown() {
            const container = document.getElementById('carListDropdown');
            container.innerHTML = CAR_PRESETS.map((car, index) => `
                <button onclick="selectCarByIndex(${index})" class="w-full text-left p-3 hover:bg-zinc-800 border-b border-zinc-900/40 text-xs font-mono text-zinc-300 transition-colors flex items-center justify-between group">
                    <span class="font-bold text-white group-hover:text-[var(--accent)] transition-colors">${car.name}</span>
                    <span class="text-[10px] text-zinc-500 uppercase">${car.drivetrain} • ${car.category}</span>
                </button>
            `).join('');
            
            // Set input value to default preset
            document.getElementById('carInput').value = selectedCarPreset.name;
        }

        function toggleCarList() {
            const drop = document.getElementById('carListDropdown');
            drop.classList.toggle('hidden');
        }

        // Dropdown select trigger handler
        function selectCarByIndex(idx) {
            selectedCarPreset = CAR_PRESETS[idx];
            document.getElementById('carInput').value = selectedCarPreset.name;
            document.getElementById('carListDropdown').classList.add('hidden');
            runCalculations();
        }

        // Update active modes tab colors
        function setDrivingStyle(style) {
            activeDrivingStyle = style;
            const styles = ['weave', 'vmax', 'drift', 'grip'];
            styles.forEach(s => {
                const btn = document.getElementById(`btn-mode-${s}`);
                if (btn) {
                    if (s === style) {
                        btn.className = "px-3 py-1.5 text-xs font-bold rounded-lg btn-tactile border border-zinc-800 bg-[var(--accent)] text-black";
                    } else {
                        btn.className = "px-3 py-1.5 text-xs font-bold rounded-lg btn-tactile border border-zinc-800 bg-zinc-900 text-zinc-400 hover:text-white";
                    }
                }
            });
            runCalculations();
        }

        // Expandable control sliders
        function toggleAdvancedSettings() {
            const panel = document.getElementById('advancedPanel');
            const chev = document.getElementById('advancedChevron');
            panel.classList.toggle('hidden');
            if (panel.classList.contains('hidden')) {
                chev.style.transform = 'rotate(0deg)';
            } else {
                chev.style.transform = 'rotate(180deg)';
            }
        }

        function resetAdvancedSliders() {
            document.getElementById('weightSlider').value = 0;
            document.getElementById('hpSlider').value = 0;
            document.getElementById('stiffnessSlider').value = 1.0;
            document.getElementById('tcAllowed').checked = false;
            updateSlidersText();
            runCalculations();
        }

        function updateSlidersText() {
            const w = document.getElementById('weightSlider').value;
            const h = document.getElementById('hpSlider').value;
            const s = parseFloat(document.getElementById('stiffnessSlider').value).toFixed(2);
            
            document.getElementById('weightVal').innerText = (w > 0 ? `+${w}` : w) + " kg";
            document.getElementById('hpVal').innerText = (h > 0 ? `+${h}` : h) + " HP";
            document.getElementById('stiffnessVal').innerText = s + "x";
        }

        // Apply theme variables dynamically to CSS :root element
        function applyGlobalTheme(themeName) {
            const t = THEMES[themeName];
            if (!t) return;
            
            activeThemeName = themeName;
            localStorage.setItem('theme_v29', themeName);

            document.documentElement.style.setProperty('--bg', t.bg);
            document.documentElement.style.setProperty('--card', t.card);
            document.documentElement.style.setProperty('--gradient-start', t.start);
            document.documentElement.style.setProperty('--gradient-end', t.end);
            document.documentElement.style.setProperty('--accent', t.accent);

            // Re-render theme config panel to reflect changes
            renderThemeSelectorMatrix();
            runCalculations();
        }

        function toggleLayoutPreference() {
            isGrid = !isGrid;
            localStorage.setItem('isGrid_v29', JSON.stringify(isGrid));
            document.getElementById('currentLayoutText').innerText = isGrid ? 'Grid Cards' : 'Stacked List';
            runCalculations();
        }

        function toggleCardBorderStyle() {
            cardStyle = cardStyle === 'rpm-border' ? 'gradient-stroke' : 'rpm-border';
            localStorage.setItem('cardStyle_v29', cardStyle);
            document.getElementById('currentCardStyleText').innerText = cardStyle === 'rpm-border' ? 'RPM Redline (v27)' : 'Tactile Gradient Stroke (v28)';
            runCalculations();
        }

        // Draw selection buttons in settings modal
        function renderThemeSelectorMatrix() {
            const container = document.getElementById('themeButtonsMatrix');
            container.innerHTML = Object.keys(THEMES).map(name => {
                const t = THEMES[name];
                const active = activeThemeName === name;
                return `
                    <button onclick="applyGlobalTheme('${name}')" class="p-2.5 text-left text-xs font-bold rounded-xl btn-tactile transition-all flex items-center justify-between ${
                        active 
                        ? 'bg-[#1a1c23] border-2 border-[var(--accent)] text-white shadow-lg' 
                        : 'bg-zinc-900 border border-zinc-800 text-zinc-400 hover:text-white hover:border-zinc-700'
                    }">
                        <span>${name}</span>
                        <span class="w-3.5 h-3.5 rounded-full shrink-0 border border-zinc-950" style="background: linear-gradient(135deg, ${t.start}, ${t.end})"></span>
                    </button>
                `;
            }).join('');
        }

        // 4. MAIN DEEP-TIER PHYSICS CALCULATION PIPELINE
        function runCalculations() {
            const carInputVal = document.getElementById('carInput').value;
            const tyreCompound = document.getElementById('tyreSelect').value;
            const gearRatio = document.getElementById('gearSelect').value;
            const trafficDensity = document.getElementById('trafficSelect').value;
            
            // Advanced overrides
            const weightOffset = parseInt(document.getElementById('weightSlider').value) || 0;
            const hpOffset = parseInt(document.getElementById('hpSlider').value) || 0;
            const springStiffnessMult = parseFloat(document.getElementById('stiffnessSlider').value) || 1.0;
            const isTcAllowed = document.getElementById('tcAllowed').checked;

            // Resolve chassis archetype
            const searchStr = carInputVal.toLowerCase();
            const matchedPreset = CAR_PRESETS.find(c => searchStr.includes(c.id) || searchStr.includes(c.name.toLowerCase()) || c.id.includes(searchStr));
            
            let chassisName = carInputVal || "Custom Street Chassis";
            let chassisDrivetrain = "RWD";
            let baseWeight = 1550;
            let baseHp = 450;
            let archetypeGroup = "Standard JDM/Tuner";
            let baseFrontDist = 51.5;

            if (matchedPreset) {
                chassisName = matchedPreset.name;
                chassisDrivetrain = matchedPreset.drivetrain;
                baseWeight = matchedPreset.weightKg;
                baseHp = matchedPreset.hp;
                archetypeGroup = matchedPreset.category;
                baseFrontDist = matchedPreset.weightDistFrontPct;
            } else {
                // Fallback archetype checking
                const isV8 = /corvette|mustang|viper|c7|c8|hellcat|v8|amg|shelby|charger|m4/i.test(searchStr);
                const isLight = /s2000|miata|gt86|brz|rx7|ae86|light/i.test(searchStr);
                const isSuper = /porsche|gt3|ferrari|mclaren|lamborghini/i.test(searchStr);
                const isAwd = /gtr|r35|audi|rs6|evo|wrx|quattro|awd/i.test(searchStr);

                if (isV8) {
                    chassisDrivetrain = "RWD";
                    baseWeight = 1680;
                    baseHp = 650;
                    archetypeGroup = "V8/Muscle";
                    baseFrontDist = 55.0;
                } else if (isLight) {
                    chassisDrivetrain = "RWD";
                    baseWeight = 1250;
                    baseHp = 320;
                    archetypeGroup = "Lightweight/Agile";
                    baseFrontDist = 50.0;
                } else if (isSuper) {
                    chassisDrivetrain = "RWD";
                    baseWeight = 1420;
                    baseHp = 580;
                    archetypeGroup = "Euro/Supercar";
                    baseFrontDist = 41.0;
                } else if (isAwd) {
                    chassisDrivetrain = "AWD";
                    baseWeight = 1720;
                    baseHp = 700;
                    archetypeGroup = "Euro/Supercar";
                    baseFrontDist = 54.0;
                }
            }

            // Calculations parameters
            const finalWeightKg = Math.max(700, baseWeight + weightOffset);
            const finalHp = Math.max(100, baseHp + hpOffset);
            const hpPerTon = Math.round((finalHp / (finalWeightKg / 1000)) * 10) / 10;

            // Trigger variables
            const isHeavyTraffic = trafficDensity === 'heavy';
            const isDrift = tyreCompound === 'drift' || gearRatio === 'vshort' || activeDrivingStyle === 'drift';
            const isVmax = gearRatio === 'long' || activeDrivingStyle === 'vmax';

            // 1. TYRES PSI (Cold setup matching)
            let psiFront = isDrift ? 32.0 : 26.0;
            let psiRear = isDrift ? 32.0 : 27.5;
            if (tyreCompound === 'street') {
                psiFront = isDrift ? 32.0 : 27.0;
                psiRear = 28.0;
            } else if (tyreCompound === 'rain') {
                psiFront = isDrift ? 32.0 : 29.0;
                psiRear = 29.5;
            } else if (tyreCompound === 'drift') {
                psiFront = 32.0;
                psiRear = 35.0; // High slide compound breakthrough pressure
            }

            // 2. ALIGNMENT MATHS
            let camberFront = -2.7;
            let camberRear = isDrift ? -0.2 : -1.8;
            let toeFront = 0.05;
            let toeRear = isDrift ? 0.0 : 0.12;

            // Traffic logic alignment adjustments
            if (isHeavyTraffic) {
                toeRear = 0.08; // shaved down tightly for lightning-quick yaw rotation response
            }

            // Archetype modifications
            const isArchetypeV8 = archetypeGroup === 'V8/Muscle';
            const isArchetypeLight = archetypeGroup === 'Lightweight/Agile';

            // 3. SUSPENSION SPRINGS
            let springRateF = 110; // baseline fallback
            let springRateR = 110;

            if (isArchetypeV8) {
                springRateF = 120;
                springRateR = 120;
            } else if (isArchetypeLight) {
                springRateF = 100;
                springRateR = 100;
            }

            // Apply stiffness fine-tuning modifier safely
            springRateF = Math.round(springRateF * springStiffnessMult * 10) / 10;
            springRateR = Math.round(springRateR * springStiffnessMult * 10) / 10;

            let rideHeightF = 80;
            let rideHeightR = 85;

            // 4. DIFFERENTIAL AND BRAKES
            let diffPower = 58; // baseline fallback
            let diffPreload = 30; // standard Nm
            let brakeBias = 56; // default percentage

            if (isArchetypeV8) {
                diffPower = 52;
            } else if (isArchetypeLight) {
                diffPower = 62;
            }

            if (isDrift) {
                diffPower = 85;
                diffPreload = 40;
            }

            if (isHeavyTraffic) {
                brakeBias = 55; // 1% rearward brake shift to encourage crisp trail braking rotations
            }

            // 5. AERODYNAMICS ADJUSTMENTS
            let wingF = 6;
            let wingR = 10;
            if (isVmax) {
                wingF = 1; // absolute low-resistance top-end speeds
                wingR = 2;
            } else if (activeDrivingStyle === 'grip') {
                wingF = 9;
                wingR = 14;
            }

            // 6. BENCHMARK TELEMETRY ESTIMATES
            let lateralGripG = tyreCompound === 'dry' ? 1.42 : tyreCompound === 'street' ? 1.22 : tyreCompound === 'rain' ? 1.02 : 0.90;
            if (chassisDrivetrain === 'AWD') lateralGripG += 0.06;
            const finalLatG = Math.round((lateralGripG + (springStiffnessMult * 0.04)) * 100) / 100;

            const weaveAgility = Math.min(100, Math.max(30, Math.round(
                (100 - (finalWeightKg / 2100) * 45) + 
                (chassisDrivetrain === 'RWD' ? 12 : 6) + 
                (isHeavyTraffic ? 10 : 0)
            )));

            const vmaxSpeedMPH = Math.min(275, Math.round(195 + (finalHp / 6.5) - (wingR * 1.5) + (isVmax ? 18 : 0)));
            const frontRollPercent = Math.round((springRateF / (springRateF + springRateR)) * 100);
            const recommendedFfbGain = Math.min(100, Math.max(40, Math.round(95 - (finalWeightKg / 2200) * 15)));

            // 7. WRITE SPECIFIC UI STRINGS
            document.getElementById('carTitle').innerText = chassisName;
            document.getElementById('carDrivetrain').innerText = chassisDrivetrain;
            document.getElementById('carWeight').innerText = finalWeightKg + " kg";
            document.getElementById('carHp').innerText = finalHp + " HP";
            document.getElementById('carPwrWeight').innerText = hpPerTon + " HP/Ton";
            document.getElementById('carArchetype').innerText = archetypeGroup;

            // Telemetry indicators
            document.getElementById('specGrip').innerHTML = finalLatG + ' <span class="text-xs text-zinc-500 font-medium">G</span>';
            document.getElementById('specWeave').innerHTML = weaveAgility + ' <span class="text-xs text-zinc-500 font-medium">/100</span>';
            document.getElementById('specVmax').innerHTML = vmaxSpeedMPH + ' <span class="text-xs text-zinc-500 font-medium">MPH</span>';
            document.getElementById('specRoll').innerText = frontRollPercent + '%';

            // Corner wheel indicators
            document.getElementById('diagPsiLF').innerText = psiFront.toFixed(1) + " PSI";
            document.getElementById('diagPsiRF').innerText = psiFront.toFixed(1) + " PSI";
            document.getElementById('diagPsiLR').innerText = psiRear.toFixed(1) + " PSI";
            document.getElementById('diagPsiRR').innerText = psiRear.toFixed(1) + " PSI";

            document.getElementById('diagCamLF').innerText = "Cam: " + camberFront.toFixed(1) + "°";
            document.getElementById('diagCamRF').innerText = "Cam: " + camberFront.toFixed(1) + "°";
            document.getElementById('diagCamLR').innerText = "Cam: " + camberRear.toFixed(1) + "°";
            document.getElementById('diagCamRR').innerText = "Cam: " + camberRear.toFixed(1) + "°";

            document.getElementById('guideRearToe').innerText = toeRear.toFixed(2) + "°";
            document.getElementById('guideFfb').innerText = recommendedFfbGain + "%";

            // Visual layout structure for the setup grids
            const results = {
                "Tyres Pressures": {
                    "LF Cold PSI": psiFront.toFixed(1),
                    "RF Cold PSI": psiFront.toFixed(1),
                    "LR Cold PSI": psiRear.toFixed(1),
                    "RR Cold PSI": psiRear.toFixed(1),
                    "AC Compound": tyreCompound.toUpperCase()
                },
                "Wheel Alignment": {
                    "LF Camber": camberFront.toFixed(1) + "°",
                    "RF Camber": camberFront.toFixed(1) + "°",
                    "LR Camber": camberRear.toFixed(1) + "°",
                    "RR Camber": camberRear.toFixed(1) + "°",
                    "Front Toe": "+" + toeFront.toFixed(2) + "°",
                    "Rear Toe": "+" + toeRear.toFixed(2) + "°"
                },
                "Suspension Rate": {
                    "F Height": rideHeightF + " mm",
                    "R Height": rideHeightR + " mm",
                    "LF Spring": springRateF + " N/mm",
                    "RF Spring": springRateF + " N/mm",
                    "LR Spring": springRateR + " N/mm",
                    "RR Spring": springRateR + " N/mm"
                },
                "Dampers Profile": {
                    "Front Bump": Math.round(4500 * springStiffnessMult),
                    "Front Rebound": Math.round(5200 * springStiffnessMult),
                    "Rear Bump": Math.round(4000 * springStiffnessMult),
                    "Rear Rebound": Math.round(5000 * springStiffnessMult)
                },
                "Differential & Brakes": {
                    "Power Lockup": diffPower + "%",
                    "Coast Lockup": "25%",
                    "Diff Preload": diffPreload + " Nm",
                    "Brake Bias": brakeBias + "%",
                    "Brake Power": "100%"
                },
                "Aero & Transmission": {
                    "Front Wing": wingF + "°",
                    "Rear Wing": wingR + "°",
                    "Final Drive": gearRatio === 'vshort' ? '4.10' : gearRatio === 'short' ? '3.73' : gearRatio === 'long' ? '3.08' : '3.45',
                    "Traction Ctrl": isTcAllowed ? "ENABLED" : "DISABLED",
                    "Peak Top Speed": vmaxSpeedMPH + " MPH"
                }
            };

            // Inject Cards View Grid layout
            const cardsGrid = document.getElementById('cardsGrid');
            cardsGrid.className = isGrid ? "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5" : "space-y-4";

            cardsGrid.innerHTML = Object.entries(results).map(([category, stats]) => {
                const borderClass = cardStyle === 'rpm-border' ? 'rpm-border' : 'gradient-stroke';
                return `
                    <div class="${borderClass} p-[1px]">
                        <div class="bg-[var(--card)] p-5 h-full rounded-xl flex flex-col justify-between shadow-lg">
                            <div>
                                <div class="flex items-center justify-between mb-4 border-b border-zinc-800/80 pb-2 select-none">
                                    <h3 class="text-white font-bold tracking-tight uppercase text-xs flex items-center gap-2">
                                        <span class="w-2 h-2 rounded-full bg-[var(--accent)] inline-block"></span>
                                        ${category}
                                    </h3>
                                    <span class="text-[10px] font-mono text-zinc-500 uppercase">AC SPEC</span>
                                </div>
                                <div class="grid grid-cols-2 gap-x-3 gap-y-3.5">
                                    ${Object.entries(stats).map(([k, v]) => `
                                        <div class="p-2 rounded-lg bg-zinc-900/45 border border-zinc-800/50">
                                            <div class="data-label">${k}</div>
                                            <div class="data-val text-sm font-black mt-0.5">${v}</div>
                                        </div>
                                    `).join('')}
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');

            // Build dynamic setup.ini content string
            const iniStr = `; ===================================================
; Assetto Corsa / No Hesi Setup Configuration File
; Chassis Target: ${chassisName}
; Generated by No Hesi Tuning Lab Engine v1.8.7
; ===================================================

[TYRES]
PRESSURE_LF=${psiFront.toFixed(1)}
PRESSURE_RF=${psiFront.toFixed(1)}
PRESSURE_LR=${psiRear.toFixed(1)}
PRESSURE_RR=${psiRear.toFixed(1)}
COMPOUND=${tyreCompound.toUpperCase()}

[ALIGNMENT]
CAMBER_LF=${camberFront.toFixed(1)}
CAMBER_RF=${camberFront.toFixed(1)}
CAMBER_LR=${camberRear.toFixed(1)}
CAMBER_RR=${camberRear.toFixed(1)}
TOE_OUT_LF=${toeFront.toFixed(2)}
TOE_OUT_RF=${toeFront.toFixed(2)}
TOE_OUT_LR=${toeRear.toFixed(2)}
TOE_OUT_RR=${toeRear.toFixed(2)}

[SUSPENSION]
SPRING_RATE_LF=${springRateF}
SPRING_RATE_RF=${springRateF}
SPRING_RATE_LR=${springRateR}
SPRING_RATE_RR=${springRateR}
HEIGHT_F=${rideHeightF}
HEIGHT_R=${rideHeightR}

[DIFFERENTIAL]
POWER=${diffPower}
PRELOAD=${diffPreload}

[BRAKES]
DATA_BIAIS=${brakeBias}
DATA_POWER=100

[AERO]
WING_FRONT=${wingF}
WING_REAR=${wingR}
`;
            document.getElementById('iniTextArea').value = iniStr;
            document.getElementById('iniModalCarName').innerText = "setup.ini generated for " + chassisName;
        }

        // Copy setup text content
        function copyIniToClipboard() {
            const txt = document.getElementById('iniTextArea');
            txt.select();
            document.execCommand('copy');
            
            const btnSpan = document.querySelector('#copyIniBtn span');
            btnSpan.innerText = "COPIED TO CLIPBOARD!";
            setTimeout(() => {
                btnSpan.innerText = "Copy INI Parameters";
            }, 2000);
        }

        // Custom local persistence list of setups
        function renderPresetsList() {
            const container = document.getElementById('presetsListContainer');
            
            // Badge counter update
            const badge = document.getElementById('presetsCountBadge');
            if (customPresets.length > 0) {
                badge.innerText = customPresets.length;
                badge.classList.remove('hidden');
            } else {
                badge.classList.add('hidden');
            }

            if (customPresets.length === 0) {
                container.innerHTML = `
                    <div class="p-8 text-center border border-dashed border-zinc-800 rounded-xl bg-zinc-900/30">
                        <p class="text-xs text-zinc-500 select-none">No custom setups saved yet.</p>
                        <p class="text-[10px] text-zinc-600 mt-1 select-none">Tweak values and save your setups to LocalStorage!</p>
                    </div>
                `;
                return;
            }

            container.innerHTML = customPresets.map((preset, index) => `
                <div class="p-3.5 bg-zinc-900 border border-zinc-800/80 hover:border-zinc-700 rounded-xl flex items-center justify-between gap-3">
